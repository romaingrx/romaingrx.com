---
import Dialog from '@/components/ui/dialog.astro';
import Gallery from './gallery.astro';
import PhotoStack from './photostack.astro';
import type { ImageItem } from './types';

interface Props {
  id?: string;
  images: ImageItem[];
  size?: 'sm' | 'md' | 'lg';
  startIndex?: number;
  showCaptions?: boolean;
}

const {
  id = `gallery-${Math.random().toString(36).substring(2, 11)}`,
  images,
  size = 'md',
  startIndex = 0,
  showCaptions,
} = Astro.props;
const DIALOG_ID = `${id}-dialog`;
---

<!-- Photo Stack that opens the lightbox -->
<PhotoStack images={images} size={size} onclick={`${id}_open`} />

<!-- Lightbox Gallery using Dialog -->
<Dialog id={DIALOG_ID} className="[&>article]:h-screen [&>article]:w-screen">
  <Gallery
    id={id}
    images={images}
    startIndex={startIndex}
    showCaptions={showCaptions}
    className="h-full w-full"
  />
</Dialog>

<script is:inline define:vars={{ id, startIndex }}>
  // Global function to open gallery
  const dialogId = `${id}-dialog`;
  window[`${id}_open`] = (index = startIndex) => {
    const dialog = document.getElementById(dialogId);
    if (dialog) {
      // Set the start index for the gallery
      const gallery = dialog.querySelector('astro-gallery');
      if (gallery) {
        gallery.currentIndex = index;
        gallery.updateDisplay();
      }
      dialog.showModal();
    }
  };
</script>
