---
import Time from '@/components/ui/time.astro';
import { routes } from '@/configs/routes';
import type { NoteWithAuthors } from '@/lib/collections';
import { cn } from '@/lib/utils';

interface Props {
  note: NoteWithAuthors;
  className?: string;
}

const { note, className } = Astro.props;
---

<a href={routes.note(note)} class={cn('group block no-underline', className)}>
  <div class="bg-card hover:bg-accent/40 overflow-hidden rounded-xl border p-4 transition-colors">
    <div class="flex flex-col gap-1.5">
      <h2
        class="group-hover:text-primary line-clamp-2 text-base font-semibold tracking-tight transition-colors"
      >
        {note.data.title}
      </h2>
      {
        note.data.description && (
          <p class="text-muted-foreground line-clamp-2 text-sm leading-relaxed">
            {note.data.description}
          </p>
        )
      }
      <div class="text-muted-foreground flex items-center gap-1.5 text-xs">
        <Time date={note.data.published_date} />
        <span>&middot;</span>
        <span>{note.readingTime}</span>
      </div>
    </div>
  </div>
</a>
