---
import type { HTMLAttributes } from 'astro/types';
import { cn } from '@/lib/utils';

type Variant = 'default' | 'secondary' | 'destructive' | 'outline' | 'active';

interface Props extends HTMLAttributes<'span'> {
  variant?: Variant;
  className?: string;
}

const variantClass: Record<Variant, string> = {
  default: 'badge',
  secondary: 'badge-secondary',
  destructive: 'badge-destructive',
  outline: 'badge-outline',
  active: 'badge border-transparent bg-violet-500/10 text-violet-500 shadow hover:bg-violet-500/20',
};

const { variant = 'default', className, class: cls, ...props } = Astro.props;
---

<span class={cn(variantClass[variant], className, cls)} {...props}>
  <slot />
</span>
