---
import type { HTMLAttributes } from 'react';
import DynamicTime from './react/DynamicTime.tsx';

interface Props extends Omit<HTMLAttributes<HTMLTimeElement>, 'dateTime'> {
  date: Date;
  formatStr?: string;
}

const { date, ...props } = Astro.props;
---

<DynamicTime client:load date={date} {...props} />
