---
import { cn } from '@/lib/utils';
import { formatDate } from '@/lib/format';

interface Props {
  date: Date;
  className?: string;
  class?: string;
}

const { date, className, class: cls } = Astro.props;
---

<time
  datetime={date.toISOString()}
  class={cn('text-xs whitespace-nowrap text-muted-foreground', className, cls)}
>
  {formatDate(date)}
</time>
