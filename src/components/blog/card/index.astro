---
import { Image } from 'astro:assets';
import Time from '@/components/ui/time.astro';
import { routes } from '@/configs/routes';
import type { BlogPostWithAuthors } from '@/lib/collections';
import { cn } from '@/lib/utils';
import BlogPostBackground from './background';

interface Props {
  post: BlogPostWithAuthors;
  className?: string;
  showDescription?: boolean;
}

const { post, className, showDescription = true } = Astro.props;
const hasCover = !!post.data.cover;
---

<a href={routes.blog(post)} class={cn('group block no-underline', className)}>
  <div class="bg-muted/50 relative aspect-[16/10] overflow-hidden rounded-xl">
    <div
      class="pointer-events-none absolute inset-0 transition-transform duration-500 group-hover:scale-105"
    >
      <BlogPostBackground value={post.id} />
    </div>
    {
      hasCover && (
        <Image
          src={post.data.cover!}
          alt={post.data.title}
          class="pointer-events-none relative z-10 h-full w-full object-contain p-6"
          width={600}
          height={400}
        />
      )
    }
  </div>

  <div class="flex flex-col gap-1.5 pt-3">
    <div class="text-muted-foreground flex items-center gap-1.5 text-xs">
      {post.data.categories[0] && <span class="capitalize">{post.data.categories[0]}</span>}
      <span>&middot;</span>
      <Time date={post.data.published_date} />
      <span>&middot;</span>
      <span>{post.readingTime}</span>
    </div>
    <h2
      class="group-hover:text-primary line-clamp-2 text-base leading-snug font-semibold tracking-tight transition-colors"
    >
      {post.data.title}
    </h2>
    {
      showDescription && post.data.description && (
        <p class="text-muted-foreground line-clamp-2 text-sm leading-relaxed">
          {post.data.description}
        </p>
      )
    }
  </div>
</a>
