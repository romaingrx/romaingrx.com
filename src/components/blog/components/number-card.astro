---
import { ArrowUpRight } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { cn } from '@/lib/utils';

export interface Props {
  title: string;
  value: number;
  description?: string;
  link?: string;
  class?: string;
}

const { title, value, description, link, class: className } = Astro.props;
---

<Card className={cn('flex flex-row items-center justify-between gap-4 px-4 py-3', className)}>
  <div class="flex min-w-0 flex-col gap-0.5">
    <CardTitle className="text-sm font-medium">{title}</CardTitle>
    {description && <CardDescription className="text-xs">{description}</CardDescription>}
  </div>
  <div class="flex shrink-0 items-center gap-2">
    <span class="text-2xl font-bold tabular-nums">{value.toLocaleString()}</span>
    {
      link && (
        <a href={link} target="_blank">
          <Button variant="secondary" size="sm" className="group">
            <ArrowUpRight className="size-4 transition-all duration-300 group-hover:-translate-y-1 group-hover:translate-x-1" />
          </Button>
        </a>
      )
    }
  </div>
</Card>
