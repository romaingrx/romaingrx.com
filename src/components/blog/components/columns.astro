---
import { cva, type VariantProps } from 'class-variance-authority';
import { cn } from '@/lib/utils';

const columns = cva('grid grid-cols-1 gap-4', {
  variants: {
    columns: {
      1: 'md:grid-cols-1',
      2: 'md:grid-cols-2',
      3: 'md:grid-cols-3',
      4: 'md:grid-cols-4',
    },
    space: {
      around: 'md:justify-around',
      between: 'md:justify-between',
      evenly: 'md:justify-evenly',
    },
  },
  defaultVariants: {
    columns: 2,
    space: 'between',
  },
});

type ColumnsVariants = VariantProps<typeof columns>;

interface Props extends ColumnsVariants {
  spread?: boolean;
  class?: string;
}

const { columns: cols, space, spread = false, class: className, ...rest } = Astro.props;
---

<div class={cn(columns({ columns: cols, space }), spread && 'columns-spread', className)} {...rest}>
  <slot />
</div>

<style>
  /* Stretch astro-island wrappers and their children to fill column height */
  div :global(> astro-island) {
    display: flex;
    flex-direction: column;
  }
  div :global(> astro-island > *) {
    flex: 1;
  }
</style>
