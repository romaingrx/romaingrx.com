---
import ContinueReading from '@/components/animations/continue-reading.astro';
import StackedAuthors from '@/components/blog/author/stacked-authors.astro';
import Resources from '@/components/blog/resources/index.astro';
import Shell from '@/components/Shell.astro';
import { resolveResourceValue } from '@/configs/resources';
import type { BlogPostWithAuthors } from '@/lib/collections';
import Time from '../ui/time.astro';
import BlogPostBackground from './card/background';
import SharingBadges from './sharing-badges.astro';

interface Props {
  post: BlogPostWithAuthors;
  class?: string;
}

const { post, class: className = '' } = Astro.props;
const resources = post.data.resources.map((r) => ({
  ...r,
  value: resolveResourceValue(r.value, { collection: 'blog', entryId: post.id }),
}));
---

<header
  class:list={[
    'relative flex w-full flex-col items-center justify-center',
    'overflow-hidden rounded-b-xl py-16',
    'min-h-[calc(100vh-4rem)]',
    'animate-[fade-in-up_0.5s_ease-out_both]',
    className,
  ]}
>
  <!-- Background with subtle gradient -->
  <div class="absolute inset-0 opacity-20">
    <BlogPostBackground value={post.id} />
  </div>

  <!-- Main Content -->
  <Shell type="article">
    <div class="relative z-10 mx-auto text-center">
      <!-- Meta Information -->
      <div class="text-muted-foreground mb-8 flex items-center justify-center gap-2 text-sm">
        <Time
          date={post.data.published_date}
          className="text-sm"
          transition:name={`${post.id}-published-date`}
        />
        <span class="leading-none">·</span>
        <span transition:name={`${post.id}-reading-time`}>{post.readingTime}</span>
      </div>

      <!-- Title -->
      <h1
        class="mb-6 bg-gradient-to-br from-gray-900 to-gray-700 bg-clip-text pb-1 text-4xl font-bold tracking-tight text-transparent md:text-5xl lg:text-6xl dark:from-white dark:to-gray-200"
        style="min-width: min(100%, 600px);"
        transition:name={`${post.id}-title`}
      >
        {post.data.title}
      </h1>

      <!-- Description -->
      <p
        class="text-muted-foreground mb-8 text-lg md:text-xl"
        transition:name={`${post.id}-description`}
      >
        {post.data.description}
      </p>

      <!-- Resources -->
      {
        post.data.resources.length > 0 && (
          <div class="relative mt-4">
            <div class="flex flex-col gap-3 text-start">
              <span class="text-muted-foreground text-sm font-medium">Resources</span>
              <Resources resources={resources} />
            </div>
          </div>
        )
      }

      <div class="relative mt-4 flex flex-row justify-between">
        <div class="flex flex-col gap-3 text-start">
          <span class="text-muted-foreground text-sm font-medium">Written by</span>
          <StackedAuthors authors={post.authors} transition:name={`${post.id}-authors`} />
        </div>
        <div class="flex flex-col gap-3 text-start">
          <span class="text-muted-foreground text-sm font-medium">Share on</span>
          <SharingBadges post={post} />
        </div>
      </div>
    </div>
  </Shell>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 transform">
    <ContinueReading />
  </div>
</header>

<style>
  @media (prefers-reduced-motion: reduce) {
    header {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
