---
import { Icon } from '@iconify/react/dist/iconify.js';
import DiscussOn from '@/components/blog/discuss-on.astro';
import Comments from '@/components/comments.astro';
import { resolveResourceValue } from '@/configs/resources';
import type { BlogPostWithAuthors } from '@/lib/collections';
import { formatDate } from '@/lib/format';
import { cn } from '@/lib/utils';
import CategoryBadge from '../category-badge.astro';
import ResourceBadges from '../resources/index.astro';
import TagBadge from '../tag-badge.astro';
import AuthorCards from './author-cards.astro';
import RelatedPosts from './related-posts.astro';

interface Props {
  post: BlogPostWithAuthors;
}

const { post } = Astro.props;
const { authors } = post;
const { tags, categories, updated_date, related_posts } = post.data;
const resources = post.data.resources.map((r) => ({
  ...r,
  value: resolveResourceValue(r.value, { collection: 'blog', entryId: post.id }),
}));
const hasRelatedContent = related_posts || tags.length > 0;
---

<footer class="mt-16 flex flex-col gap-8">
  <hr />

  <!-- Thank You & Discuss Section -->
  <DiscussOn post={post} />

  <!-- Metadata Section -->
  <div
    class={cn(
      'rounded-lg border bg-card p-6 text-card-foreground shadow-sm',
      [resources.length, tags.length, categories.length, updated_date].some(Boolean)
        ? 'flex'
        : 'hidden'
    )}
  >
    <div class="space-y-6">
      <!-- Tags and Categories -->
      <div class="space-y-4">
        {
          resources.length > 0 && (
            <div class="space-y-3">
              <h3 class="text-muted-foreground text-sm font-medium">Resources</h3>
              <ResourceBadges resources={resources} />
            </div>
          )
        }
        {
          tags.length > 0 && (
            <div class="space-y-3">
              <h3 class="text-muted-foreground text-sm font-medium">Tags</h3>
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <TagBadge tag={tag} />
                ))}
              </div>
            </div>
          )
        }
        {
          categories.length > 0 && (
            <div class="space-y-3">
              <h3 class="text-muted-foreground text-sm font-medium">Categories</h3>
              <div class="flex flex-wrap gap-2">
                {categories.map((category) => (
                  <CategoryBadge category={category} />
                ))}
              </div>
            </div>
          )
        }
      </div>

      <!-- Update Information -->
      {
        updated_date && (
          <div class="text-muted-foreground flex items-center gap-2 text-sm">
            <Icon icon="mdi:calendar-clock" className="size-4" />
            <span>Last updated on {formatDate(updated_date)}</span>
          </div>
        )
      }
    </div>
  </div>

  <!-- Authors Section (Hidden) -->
  {
    authors.length > 0 && (
      <div class="mb-16 hidden">
        <h2 class="mb-6 text-2xl font-semibold tracking-tight">
          About the author{authors.length > 1 ? 's' : ''}
        </h2>
        <AuthorCards authors={authors} />
      </div>
    )
  }

  <!-- Related Content Section -->
  {
    hasRelatedContent && (
      <div class="mb-16">
        <h2 class="mb-6 text-2xl font-semibold tracking-tight">
          {post.data.related_posts ? 'Related Content' : 'More Posts'}
        </h2>
        <RelatedPosts post={post} />
      </div>
    )
  }

  <!-- Comments Section -->
  <div class="my-8">
    <Comments />
  </div>
</footer>
