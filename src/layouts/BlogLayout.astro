---
import type { BlogPostWithAuthors } from '@/lib/collections';
import '@/styles/katex.css';
import BaseLayout from './BaseLayout.astro';

interface Props {
  post: BlogPostWithAuthors;
}

const { post } = Astro.props;

// Create a cache-busting URL for the OG image using URLSearchParams for proper encoding
const ogImageUrl = `/og/blog/${post.id}.png`;
---

<BaseLayout title={post.data.title} description={post.data.description} ogImage={ogImageUrl}>
  <link
    slot="head"
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css"
    crossorigin="anonymous"
  />
  <slot />
</BaseLayout>
